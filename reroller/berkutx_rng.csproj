<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>     <!-- x86 runs on any Windows (matches the 32-bit game's reach) -->
    <SelfContained>true</SelfContained>            <!-- the .NET runtime is bundled in the exe — no prerequisite -->
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>true</PublishTrimmed>          <!-- trim the bundled runtime to keep the single exe small -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <AssemblyName>berkutx_rng</AssemblyName>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <InvariantGlobalization>true</InvariantGlobalization>
    <DebugType>none</DebugType>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
  </PropertyGroup>

  <ItemGroup>
    <!-- the authored arena, embedded so the exe ships alone (read at runtime as "arena.sg") -->
    <EmbeddedResource Include="assets/arena.sg">
      <LogicalName>arena.sg</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
